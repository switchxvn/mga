{
  "name": "@ew/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "typeorm": "ts-node -r tsconfig-paths/register -P ./tsconfig.json ./node_modules/typeorm/cli.js",
    "migration:create": "yarn typeorm migration:create",
    "migration:generate": "yarn typeorm migration:generate -d libs/database/src/config/typeorm.config.ts",
    "migration:run": "yarn typeorm migration:run -d libs/database/src/config/typeorm.config.ts",
    "migration:revert": "yarn typeorm migration:revert -d libs/database/src/config/typeorm.config.ts",
    "migration:show": "yarn typeorm migration:show -d libs/database/src/config/typeorm.config.ts",
    "seed": "ts-node -r tsconfig-paths/register libs/database/src/commands/seed.command.ts",
    "dev:backend": "nx run backend:serve:development",
    "dev:frontend": "cd apps/frontend && npx nuxt dev --dotenv apps/frontend/.env --no-typecheck",
    "typecheck:frontend": "cd apps/frontend && vue-tsc --project vue-tsc.config.json",
    "typecheck:frontend:watch": "cd apps/frontend && vue-tsc --project vue-tsc.config.json --watch",
    "nx:frontend": "nx run frontend:serve --verbose",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run typecheck:frontend:watch\"",
    "dev:daemon": "npx nx daemon",
    "cleanup": "powershell -ExecutionPolicy Bypass -File cleanup.ps1"
  },
  "private": true,
  "dependencies": {
