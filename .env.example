# GitHub Container Registry credentials
GITHUB_USERNAME=your-github-username
GITHUB_TOKEN=your-github-token
REGISTRY=ghcr.io

# Application settings
APP_NAME=cable-car
NETWORK_NAME=app-network

# Ports (optional - defaults set in deploy.sh)
# Các port runtime cho frontend/admin nên đặt trong:
# - apps/frontend/.env.local
# - apps/admin/.env.local
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
FRONTEND_PORT=3000
ADMIN_PORT=3001
BACKEND_PORT=3333
API_PORT=4000

# Other application settings
NODE_ENV=production

# Frontend (shared .env, namespaced vars)
FRONTEND_NUXT_HOST=localhost
FRONTEND_NUXT_PORT=4201
FRONTEND_API_BASE=http://localhost:3333
FRONTEND_SITE_URL=http://localhost:4201
FRONTEND_SITE_NAME=Ecommerce Web

# Admin (shared .env, namespaced vars)
ADMIN_NUXT_HOST=localhost
ADMIN_NUXT_PORT=4300
ADMIN_API_BASE=http://localhost:3333
ADMIN_BASE_URL=/admin/

# Backend settings
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=123456
# Nếu password có ký tự đặc biệt (vd: $, !, #), nên dùng single quote khi set trong shell:
# export DB_PASSWORD='your$trongP@ss'
DB_DATABASE=ew
DB_SYNCHRONIZE=true
JWT_SECRET=your-secret-key-should-be-very-long-and-secure
JWT_EXPIRES_IN=1d
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM=your-email@gmail.com
FRONTEND_URL=http://localhost:4201
API_PREFIX=api
SWAGGER_ENABLED=true
CORS_ENABLED=true
CORS_ORIGINS=http://localhost:3000,http://localhost:4200,http://localhost:4201,http://localhost:4300,http://127.0.0.1:4200,http://127.0.0.1:4201,http://127.0.0.1:4300,http://localhost:*
PAYOS_CLIENT_ID=your-payos-client-id
PAYOS_API_KEY=your-payos-api-key
PAYOS_CHECKSUM_KEY=your-payos-checksum-key
